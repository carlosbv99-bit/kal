# Copiar a .env y completar. NUNCA commitear .env real.

# --- Núcleo ---
AGENT_ENV=development
LOG_LEVEL=INFO

# --- Credenciales multimodales ---
# IMPORTANTE: estas claves NO deben ser accesibles desde el sandbox_runner
# ni desde código generado dinámicamente por el agente. Solo el proceso
# orquestador (agent_core) las lee, y únicamente al invocar adaptadores
# ya validados y promovidos (ver tool_integration/registry.py).
IMAGE_GEN_API_KEY=
AUDIO_GEN_API_KEY=
VIDEO_GEN_API_KEY=

# --- Memoria ---
MID_TERM_DB_URL=sqlite:///data/mid_term/memory.db
LONG_TERM_VECTOR_HOST=vector_store
LONG_TERM_VECTOR_PORT=8000

# --- Sandbox ---
SANDBOX_RUNNER_URL=http://sandbox_runner:9000
